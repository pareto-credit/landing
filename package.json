{
  "name": "pareto-landing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-agent-discovery.js",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/create-github-pages-fallback.js",
    "deploy:clean": "gh-pages-clean",
    "deploy": "npm run deploy:clean && gh-pages -d dist --dotfiles --nojekyll --cname pareto.credit --repo git@github.com:pareto-credit/landing.git",
    "deploy:worker": "npx wrangler deploy",
    "deploy:all": "npm run build:deploy && npm run deploy:worker",
    "build:deploy": "npm run build && npm run deploy",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@idle-multiverse/data-access": "file:./packages/data-access",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.168.2",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.183.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/router-plugin": "^1.168.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
